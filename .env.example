# Cal.com — server-side API key for availability endpoint and booking creation
# cal.com/settings/developer/api-keys
CAL_API_KEY=cal_live_...

# Site URL (used for OG images, sitemap, structured data)
NEXT_PUBLIC_SITE_URL=https://okamilabs.com

# Stripe — required for /book checkout flow
# Test keys from dashboard.stripe.com/test/apikeys, live keys from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Beehiiv newsletter — "The Silent Brief" (optional — falls back to /tmp file storage if unset)
# Get these from Beehiiv dashboard → Settings → Integrations
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Supabase — partial booking tracking (optional — gracefully disabled if unset)
# Auto-provisioned via Vercel Marketplace, or set manually from supabase.com/dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
