# Cal.com — server-side API key for availability endpoint (cal.com/settings/developer/api-keys)
CAL_API_KEY=cal_live_...

# Cal.com — fallback direct link (used by CalEmbed component only)
NEXT_PUBLIC_CAL_LINK=https://cal.com/your-link

# Site URL (used for OG images, sitemap, structured data)
NEXT_PUBLIC_SITE_URL=https://okamilabs.com

# Stripe Payment Link for The Okami Review ($299)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://book.stripe.com/your-payment-link

# Beehiiv newsletter — "The Silent Brief" (optional — falls back to /tmp file storage if unset)
# Get these from Beehiiv dashboard → Settings → Integrations
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
